# ============================================================
# 必填
# ============================================================
DEEPSEEK_API_KEY=your-deepseek-api-key
MODEL=deepseek-chat

# ============================================================
# 连接地址
# ============================================================
MILVUS_URI=http://localhost:19530
REDIS_URI=redis://localhost:6379/0
SQLSERVER_CONN=

# ============================================================
# 模型 / 镜像
# ============================================================
HF_ENDPOINT=https://hf-mirror.com
# EMBEDDING_API_KEY=                # 设置后使用 OpenAI embeddings，否则本地 HuggingFace
# MILVUS_TOKEN=                     # Milvus 认证 token
# MILVUS_DB_NAME=default            # Milvus 数据库名

# ============================================================
# 可观测性（可选）
# ============================================================
# OTEL_TRACING_ENABLED=false        # 开启链路追踪
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# LANGCHAIN_TRACING_V2=false        # LangSmith 调试追踪
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=rag-system
